{
  "Storage": {
    "Provider": "S3"
  },
  "HangfireQueues": {
    "WorkerCount": 2,
    "Queues": [ "critical", "downloads", "ocr", "ai", "reports", "email", "default" ]
  },
  "Hangfire": {
    "EnableJobServer": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Hangfire": "Information"
    }
  }
}
