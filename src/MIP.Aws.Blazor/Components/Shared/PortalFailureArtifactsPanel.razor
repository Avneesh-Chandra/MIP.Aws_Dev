@inject IJSRuntime JS

@if (HasArtifacts)
{
    <MudStack Spacing="1">
        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@Title</MudText>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Subtitle</MudText>
        }
        <MudTabs Outlined="true" Rounded="true" PanelClass="pa-2" @bind-ActivePanelIndex="_activeTab">
            <MudTabPanel Text="Screenshot" Icon="@Icons.Material.Filled.PhotoCamera"
                         Disabled="@string.IsNullOrWhiteSpace(ScreenshotUrl)">
                @if (!string.IsNullOrWhiteSpace(ScreenshotUrl))
                {
                    <MudStack Spacing="2">
                        <MudPaper Outlined="true" Class="pa-2" Style="background:#0a0a0a;">
                            <MudImage Src="@ScreenshotUrl"
                                      Alt="Failure screenshot"
                                      Fluid="true"
                                      Style="display:block;max-height:45vh;margin:0 auto;" />
                        </MudPaper>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.OpenInNew"
                                   OnClick="@(() => OpenUrl(ScreenshotUrl))">
                            Open full size
                        </MudButton>
                    </MudStack>
                }
            </MudTabPanel>
            <MudTabPanel Text="HTML snapshot" Icon="@Icons.Material.Filled.Html"
                         Disabled="@string.IsNullOrWhiteSpace(HtmlSnapshotUrl)">
                @if (!string.IsNullOrWhiteSpace(HtmlSnapshotUrl))
                {
                    <MudStack Spacing="2">
                        <MudPaper Outlined="true" Class="pa-0" Style="height:45vh;overflow:hidden;">
                            <iframe src="@HtmlSnapshotUrl"
                                    style="width:100%;height:100%;border:0;background:#fff;"
                                    sandbox="allow-same-origin allow-scripts"
                                    title="HTML snapshot at failure"></iframe>
                        </MudPaper>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.OpenInNew"
                                   OnClick="@(() => OpenUrl(HtmlSnapshotUrl))">
                            Open in new tab
                        </MudButton>
                    </MudStack>
                }
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}

@code {
    [Parameter] public string? ScreenshotUrl { get; set; }
    [Parameter] public string? HtmlSnapshotUrl { get; set; }
    [Parameter] public string Title { get; set; } = "Page capture at failure";
    [Parameter] public string? Subtitle { get; set; } =
        "Review the portal page as captured during the failed download to choose the best AI recovery option.";

    private int _activeTab;

    private bool HasArtifacts =>
        !string.IsNullOrWhiteSpace(ScreenshotUrl) || !string.IsNullOrWhiteSpace(HtmlSnapshotUrl);

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(ScreenshotUrl))
        {
            _activeTab = 0;
        }
        else if (!string.IsNullOrWhiteSpace(HtmlSnapshotUrl))
        {
            _activeTab = 1;
        }
    }

    private async Task OpenUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return;
        }

        await JS.InvokeVoidAsync("open", url, "_blank", "noopener,noreferrer");
    }
}
