{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Hangfire": ""
  },
  "Jwt": {
    "Issuer": "https://mipaws.local",
    "Audience": "mip-aws-api",
    "SigningKey": "",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Storage": {
    "LocalRoot": "./storage"
  },
  "Aws": {
    "Region": "",
    "S3": {
      "Enabled": false,
