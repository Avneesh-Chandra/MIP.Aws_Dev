{
  "Storage": {
    "Provider": "S3",
    "PresignedUrlExpiryMinutes": 60
  },
  "Ai": {
    "Provider": "AwsBedrock",
    "Enabled": true,
    "MockMode": false
  },
  "Aws": {
    "Region": "eu-north-1",
    "S3": {
      "Enabled": true,
      "BucketName": "",
      "Prefix": "mip/"
    },
    "Ses": {
      "Enabled": true,
      "SenderEmail": "",
      "ConfigurationSet": ""
    },
    "SecretsManager": {
      "Enabled": true,
      "Prefix": "mip/"
    },
    "Bedrock": {
      "Enabled": true,
      "ModelId": "amazon.nova-lite-v1:0",
      "Region": "eu-north-1",
      "MaxTokens": 1200,
      "Temperature": 0.2,
      "TopP": 0.9,
      "TimeoutSeconds": 60
    }
  },
  "Email": {
    "Provider": "AwsSes",
    "FromEmail": "",
    "FromDisplayName": "GFH MIP AWS"
  },
  "Mail": {
    "ActiveProvider": "AwsSes",
    "DevelopmentSafetyEnabled": false,
    "RedirectAllTo": "",
